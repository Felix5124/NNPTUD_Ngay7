{
  "info": {
    "_postman_id": "c8d1130d-c4c2-4a4b-8bc7-8ce9f6c1ab01",
    "name": "Inventory API",
    "description": "Collection test cac API inventory: auto-create inventory khi tao product, add/remove stock, reservation, sold.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Product (auto create inventory)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Product {{$timestamp}}\",\n  \"price\": 100,\n  \"description\": \"product for inventory flow\",\n  \"category\": \"{{categoryId}}\",\n  \"images\": [\"https://placeimg.com/640/480/any\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "products"
          ]
        },
        "description": "Tao product moi. Server se tu tao inventory voi stock/reserved/soldCount = 0."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "let data = pm.response.json();",
              "if (data && data._id) {",
              "  pm.collectionVariables.set('productId', data._id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Get All Inventories (join product)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/inventories",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "inventories"
          ]
        },
        "description": "Lay tat ca inventories va populate product."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "let list = pm.response.json();",
              "let productId = pm.collectionVariables.get('productId');",
              "if (Array.isArray(list) && productId) {",
              "  let found = list.find(function (x) {",
              "    return x && x.product && x.product._id === productId;",
              "  });",
              "  if (found && found._id) {",
              "    pm.collectionVariables.set('inventoryId', found._id);",
              "  }",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Get Inventory By ID (join product)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/inventories/{{inventoryId}}",
